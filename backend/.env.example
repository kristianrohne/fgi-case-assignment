# Copy to .env and fill in. The app runs without these (mock LLM) if unset.

# LLM provider: "anthropic" (real Claude calls) or "mock" (deterministic stub, no key needed)
LLM_PROVIDER=mock

# Anthropic API key — only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Model used for the digest. Cheap+capable default.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# "As-of" date for all time-based risk checks (filings, mandates). ISO YYYY-MM-DD.
# Leave blank to use the real current date.
AS_OF_DATE=
